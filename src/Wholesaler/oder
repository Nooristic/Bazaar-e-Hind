<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your Cart & Checkout</title>
  <base href="../../src/Wholesaler/">

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Cormorant+Garamond:wght@400;600&display=swap');

    :root {
      --bg-overlay: rgba(255, 248, 230, 0.94);
      --card-bg: #FFF8E7;
      --text-dark: #5D4037;
      --text-light: #8D6E63;
      --gold: #D4AF37;
      --header-blue: #4169E1;
      --card-border: #E6D4B5;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Cormorant Garamond', serif;
      background: url('https://images.unsplash.com/photo-1604176354204-9268737828e4?ixlib=rb-4.0.3&auto=format&fit=crop&q=80') center/cover fixed;
      color: var(--text-dark);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* Header */
    .header {
      background: var(--header-blue);
      padding: 16px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      color: white;
      position: relative;
      z-index: 10;
    }
    .back-link {
      font-size: 1.1rem;
      color: white;
      text-decoration: none;
      font-weight: 600;
      font-family: 'Cormorant Garamond', serif;
    }
    .header-title {
      font-family: 'Playfair Display', serif;
      font-size: 2.1rem;
      font-weight: 700;
    }
    .profile-icon {
      width: 40px; height: 40px;
      background: white;
      border-radius: 50%;
      display: grid;
      place-items: center;
      font-size: 1.4rem;
      color: var(--header-blue);
    }

    /* Main Container */
    .main-container {
      flex: 1;
      padding: 40px 20px;
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 30px;
    }

    /* Cart Table */
    .cart-section {
      background: var(--bg-overlay);
      border-radius: 20px;
      padding: 30px;
      border: 2px solid var(--card-border);
      box-shadow: 0 8px 25px rgba(139, 111, 71, 0.1);
    }
    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.8rem;
      font-weight: 700;
      margin-bottom: 25px;
      color: var(--text-dark);
      text-align: center;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: white;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    }
    th {
      background: var(--gold);
      color: white;
      padding: 16px;
      font-weight: 600;
      font-family: 'Cormorant Garamond', serif;
      text-align: center;
    }
    td {
      padding: 16px;
      border-bottom: 1px solid #f0e6d2;
      vertical-align: middle;
      text-align: center;
    }
    .product-img {
      width: 70px;
      height: 70px;
      object-fit: cover;
      border-radius: 10px;
      border: 2px solid var(--gold);
    }
    .qty-input {
      width: 70px;
      padding: 8px;
      border: 2px solid var(--card-border);
      border-radius: 8px;
      text-align: center;
      font-family: inherit;
    }
    .price {
      font-weight: 600;
      color: var(--text-dark);
    }
    .remove-btn {
      background: #ff6b6b;
      color: white;
      border: none;
      padding: 8px 16px;
      border-radius: 20px;
      cursor: pointer;
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.9rem;
      transition: background 0.3s;
    }
    .remove-btn:hover {
      background: #ff5252;
    }

    /* Summary */
    .summary-section {
      background: var(--bg-overlay);
      border-radius: 20px;
      padding: 25px;
      border: 2px solid var(--card-border);
      box-shadow: 0 8px 25px rgba(139, 111, 71, 0.1);
    }
    .summary-row {
      display: flex;
      justify-content: space-between;
      margin-bottom: 12px;
      padding: 8px 0;
      font-size: 1.1rem;
    }
    .summary-row.total {
      border-top: 2px solid var(--gold);
      padding-top: 15px;
      font-weight: bold;
      font-size: 1.3rem;
      color: var(--text-dark);
    }

    /* Checkout Form */
    .checkout-section {
      background: var(--bg-overlay);
      border-radius: 20px;
      padding: 30px;
      border: 2px solid var(--card-border);
      box-shadow: 0 8px 25px rgba(139, 111, 71, 0.1);
    }
    .form-group {
      margin-bottom: 20px;
    }
    .form-group label {
      display: block;
      margin-bottom: 8px;
      font-weight: 600;
      color: var(--text-dark);
      font-size: 1.05rem;
    }
    .form-group select {
      width: 100%;
      padding: 12px 16px;
      border: 2px solid var(--card-border);
      border-radius: 10px;
      font-family: 'Cormorant Garamond', serif;
      font-size: 1rem;
      background: white;
    }
    .checkbox-group {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 25px;
      font-size: 1rem;
    }
    .checkbox-group input[type="checkbox"] {
      margin-top: 2px;
    }

    .place-order-btn {
      width: 100%;
      background: var(--gold);
      color: white;
      border: none;
      padding: 16px;
      border-radius: 30px;
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem;
      font-weight: 700;
      cursor: pointer;
      transition: background 0.3s;
      position: relative;
    }
    .place-order-btn:hover {
      background: #b8932f;
    }
    .place-order-btn::after {
      content: " ₹";
      font-size: 1.5rem;
    }

    /* Fixed Footer */
    footer {
      background: var(--bg-overlay);
      padding: 15px 40px;
      text-align: center;
      border-top: 2px solid var(--card-border);
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 100;
    }
    footer a {
      color: var(--text-dark);
      margin: 0 15px;
      text-decoration: none;
      font-size: 1rem;
      transition: color 0.3s;
    }
    footer a:hover {
      color: var(--gold);
    }

    @media (max-width: 768px) {
      .main-container { padding: 20px 15px; }
      .cart-section, .checkout-section { padding: 20px; }
      table { font-size: 0.9rem; }
      th, td { padding: 12px 8px; }
      .product-img { width: 50px; height: 50px; }
      .qty-input { width: 60px; }
      .header-title { font-size: 1.6rem; }
      .section-title { font-size: 1.4rem; }
      footer { padding: 15px 20px; }
      footer a { display: block; margin: 5px 0; }
    }
  </style>
</head>
<body>

  <div class="header">
    <a href="browse-catalog.html" class="back-link">← Back to Catalog</a>
    <h1 class="header-title">Your Cart & Checkout</h1>
    <div class="profile-icon">👤</div>
  </div>

  <div class="main-container">
    <!-- Cart Items -->
    <div class="cart-section">
      <h2 class="section-title">Your Selected Fabrics</h2>
      <table>
        <thead>
          <tr>
            <th>Image</th>
            <th>Fabric Name</th>
            <th>Quantity (m)</th>
            <th>Price/m</th>
            <th>Subtotal</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody id="cart-items">
          <!-- Items will be populated by JavaScript -->
        </tbody>
      </table>
    </div>

    <!-- Order Summary -->
    <div class="summary-section">
      <h2 class="section-title">Order Summary</h2>
      <div class="summary-row">
        <span>Subtotal:</span>
        <span id="subtotal">₹ 0</span>
      </div>
      <div class="summary-row">
        <span>Shipping:</span>
        <span>₹ 150</span>
      </div>
      <div class="summary-row total">
        <span>Total Amount:</span>
        <span id="total">₹ 0</span>
      </div>
    </div>

    <!-- Checkout Form -->
    <div class="checkout-section">
      <h2 class="section-title">Checkout Details</h2>
      <form id="checkout-form">
        <div class="form-group">
          <label for="shipping">Shipping Address</label>
          <select id="shipping" required>
            <option value="">Select Address</option>
            <option value="mumbai">Main Warehouse - Mumbai, Maharashtra</option>
            <option value="delhi">Branch Office - Delhi, NCR</option>
            <option value="surat">Showroom - Surat, Gujarat</option>
            <option value="bangalore">Distribution Center - Bangalore, Karnataka</option>
          </select>
        </div>

        <div class="form-group">
          <label for="payment">Payment Option</label>
          <select id="payment" required>
            <option value="">Select Payment</option>
            <option value="full">Full Payment (Immediate)</option>
            <option value="partial">Partial Payment (50% advance)</option>
            <option value="credit">Credit (30 days net)</option>
          </select>
        </div>

        <div class="checkbox-group">
          <input type="checkbox" id="terms" required>
          <label for="terms">I agree to the <a href="#" style="color: var(--gold);">Terms & Conditions</a></label>
        </div>

        <button type="submit" class="place-order-btn">Place Order</button>
      </form>
    </div>
  </div>

  <footer>
    <a href="#faqs">FAQs</a>
    <a href="#terms">Terms & Conditions</a>
    <a href="#privacy">Privacy Policy</a>
    <a href="#contact">Contact Support</a>
  </footer>

  <script>
    // Sample cart data
    let cartItems = [
      {
        id: 1,
        img: '../../assests/fabric_pink.jpg',
        name: 'Silk Saffron Premium',
        qty: 100,
        price: 720
      },
      {
        id: 2,
        img: '../../assests/fabric_green.jpg',
        name: 'Linen Gold Natural',
        qty: 50,
        price: 820
      },
      {
        id: 3,
        img: '../../assests/fabric_rose.jpg',
        name: 'Cotton Blue Heritage',
        qty: 75,
        price: 450
      }
    ];

    const cartBody = document.getElementById('cart-items');
    const subtotalEl = document.getElementById('subtotal');
    const totalEl = document.getElementById('total');

    function renderCart() {
      cartBody.innerHTML = '';
      let subtotal = 0;

      if (cartItems.length === 0) {
        cartBody.innerHTML = `
          <tr>
            <td colspan="6" style="text-align: center; padding: 40px; color: var(--text-light);">
              Your cart is empty. <a href="browse-catalog.html" style="color: var(--gold);">Continue Shopping</a>
            </td>
          </tr>
        `;
        subtotalEl.textContent = '₹ 0';
        totalEl.textContent = '₹ 0';
        return;
      }

      cartItems.forEach((item, index) => {
        const sub = item.qty * item.price;
        subtotal += sub;

        const row = document.createElement('tr');
        row.innerHTML = `
          <td><img src="${item.img}" class="product-img" alt="${item.name}" onerror="this.src='https://via.placeholder.com/70x70/f5deb3/e6d4b5?text=Fabric'"></td>
          <td style="text-align: left; font-weight: 600;">${item.name}</td>
          <td><input type="number" class="qty-input" value="${item.qty}" min="1" onchange="updateQty(${index}, this.value)"></td>
          <td class="price">₹ ${item.price.toLocaleString()}</td>
          <td class="price">₹ ${sub.toLocaleString()}</td>
          <td><button class="remove-btn" onclick="removeItem(${index})">Remove</button></td>
        `;
        cartBody.appendChild(row);
      });

      subtotalEl.textContent = `₹ ${subtotal.toLocaleString()}`;
      totalEl.textContent = `₹ ${(subtotal + 150).toLocaleString()}`;
    }

    function updateQty(index, newQty) {
      const qty = parseInt(newQty);
      if (qty >= 1) {
        cartItems[index].qty = qty;
        renderCart();
      }
    }

    function removeItem(index) {
      if (confirm('Remove this item from cart?')) {
        cartItems.splice(index, 1);
        renderCart();
      }
    }

    // Form submission
    document.getElementById('checkout-form').addEventListener('submit', (e) => {
      e.preventDefault();
      
      if (cartItems.length === 0) {
        alert('Your cart is empty. Please add items before placing an order.');
        return;
      }

      const shipping = document.getElementById('shipping').value;
      const payment = document.getElementById('payment').value;
      
      if (!shipping || !payment) {
        alert('Please select shipping address and payment option.');
        return;
      }

      if (!document.getElementById('terms').checked) {
        alert('Please agree to Terms & Conditions.');
        return;
      }

      const total = parseInt(totalEl.textContent.replace(/[^\d]/g, ''));
      alert(`Order placed successfully!\nTotal: ₹ ${total.toLocaleString()}\nShipping: ${shipping}\nPayment: ${payment}`);
      
      // Reset cart for demo
      cartItems = [];
      renderCart();
      document.getElementById('checkout-form').reset();
    });

    // Initial render
    renderCart();
  </script>
</body>
</html>